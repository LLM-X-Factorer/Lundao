# Gemini API Configuration
GOOGLE_API_KEY=your_gemini_api_key_here
# Model name. Default: gemini-2.5-flash (best price/perf with thinking mode).
# For max quality, use: gemini-3-pro-preview (preview, costlier).
GEMINI_MODEL=gemini-2.5-flash

# Gamma API Configuration
GAMMA_API_KEY=your_gamma_api_key_here
GAMMA_EXPORT_FORMAT=pdf  # Export format: pdf or pptx
# Note: API URL is now hardcoded in the client (https://public-api.gamma.app/v1.0/generations)

# Image Server Configuration
IMAGE_SERVER_HOST=localhost
IMAGE_SERVER_PORT=8001
IMAGE_SERVER_BASE_URL=http://localhost:8001

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Output Configuration
OUTPUT_DIR=./outputs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# LangGraph Configuration
LANGGRAPH_CHECKPOINT_DIR=./checkpoints
