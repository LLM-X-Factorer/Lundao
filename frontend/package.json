{
  "name": "lundao-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "论导 Lundao — AI 助你三分钟搞定组会 PPT (Vue 3 frontend)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "docker:build": "docker build -t lundao-frontend:latest .",
    "docker:run": "docker run -d -p 8080:80 --name lundao-frontend lundao-frontend:latest",
    "docker:stop": "docker stop lundao-frontend && docker rm lundao-frontend"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "axios": "^1.12.2",
    "dompurify": "^3.3.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "marked": "^18.0.3",
    "marked-katex-extension": "^5.1.5",
    "pinia": "^3.0.0",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.0.0"
  }
}
